## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.user.config
*.csproj.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleasePublic/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Publish output
publish/
publish-*/

# Visual Studio cache/options
.vs/
.vscode/

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg

# Local environment
.env
.env.local

# User settings that may contain sensitive data
Settings.settings

# Setup/helper documentation
GITHUB_SETUP.md
FILES_TO_COMMIT.md
