<Window x:Class="ElectroMods.SteamPathPrompt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElectroMods"
        mc:Ignorable="d"
        Title="ElectroMods - Setup" Height="420" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Background="#282828">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="#322F3D" Padding="20,18,20,18">
            <StackPanel>
                <TextBlock Text="Welcome to ElectroMods!" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <TextBlock Text="Please select the path to your Electronauts installation folder." 
                           Foreground="#CCCCCC" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           LineHeight="18"/>
                <TextBlock Text="You'll only have to do this once! :)" 
                           Foreground="#CCCCCC" 
                           FontSize="12" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content Section -->
        <StackPanel Grid.Row="1" Margin="30,35,30,35" VerticalAlignment="Center">
            <!--<TextBlock Text="Electronauts Installation Path" 
                       Foreground="White" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Margin="0,0,0,12"/>-->
            
            <TextBox x:Name="textBox" 
                     Text="Browse for path..." 
                     IsReadOnly="True"
                     Background="#1A1A1A" 
                     Foreground="#888888" 
                     BorderBrush="#444444" 
                     BorderThickness="1"
                     Padding="12,10,12,10"
                     FontSize="12"
                     Margin="0,0,0,20"/>
            
            <Button x:Name="browseButton" 
                    Click="btnOpen_Click" 
                    Content="Browse for Folder" 
                    HorizontalAlignment="Left"
                    Padding="18,11,18,11"
                    FontSize="13"
                    Height="40"
                    Width="160"
                    BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#5865F2"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}" 
                                            CornerRadius="4" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Footer Section -->
        <Border Grid.Row="2" Background="#322F3D" Padding="20,18,20,18" MinHeight="70">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💡" 
                           Foreground="#999999" 
                           FontSize="14" 
                           Margin="0,0,10,0"
                           VerticalAlignment="Top"/>
                <TextBlock Foreground="#999999" 
                           FontSize="11" 
                           TextWrapping="Wrap"
                           LineHeight="18"
                           VerticalAlignment="Center">
                    <Run Text="Tip: Usually located at:"/>
                    <LineBreak/>
                    <Run Text="C:\Program Files (x86)\Steam\steamapps\common\Electronauts"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
