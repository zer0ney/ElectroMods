<Window x:Class="ElectroMods.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElectroMods"
        mc:Ignorable="d"
        Title="ElectroMods" Height="700" Width="1250" MinHeight="700" MinWidth="1100"
        ResizeMode="CanResize"
        ContentRendered="Window_ContentRendered"
        Closing="Window_Closing">

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{DynamicResource SideMenuButtonBackground}"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="539*"/>
            <RowDefinition Height="45*"/>
        </Grid.RowDefinitions>

        <!-- status footer -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Background -->
            <Rectangle Grid.ColumnSpan="2" Fill="#322F3D"/>
            
            <!-- Status text background and border -->
            <Border Grid.Column="0" BorderBrush="#282828" BorderThickness="2" CornerRadius="4" Margin="8">
                <Border Background="#282828" CornerRadius="2">
                    <TextBlock Name="statusBarText" 
                               Text="Test" 
                               Foreground="White" 
                               FontSize="18" 
                               Padding="10,3,10,3"
                               VerticalAlignment="Center"/>
                </Border>
            </Border>
            
            <!-- Refresh Button -->
            <Button x:Name="refreshButton"
                    Grid.Column="1"
                    Click="Refresh_Click"
                    Content="Refresh" 
                    Margin="0,0,10,0"
                    VerticalAlignment="Center" 
                    Height="37"
                    Width="142"
                    Background="#282828"
                    Foreground="White"
                    BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- loading spinner-->



        <!-- left menu bar -->
        <TabControl x:Name="tabControl" TabStripPlacement="Left">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="1,1,0,1" BorderBrush="Gainsboro" CornerRadius="4,0,0,4" Margin="0,-2,0,0" Width="70">
                                    <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        ContentSource="Header"
                                        Margin="0,4,0,4" Width="59"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3E065F" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="Background" Value="#322F3D" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabControl.Background>
                <SolidColorBrush Color="#282828"/>
            </TabControl.Background>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <Image Source="Icons/songs.png" Margin="3,3,3,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="40" Height="40"/>
                        <Label Content="Songs" Foreground="White" Width="58" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- DataGrid with Border for floating effect and rounded corners -->
                    <Border Grid.Row="0" Background="Transparent" Margin="10,10,10,5" CornerRadius="6" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                        </Border.Effect>
                        <DataGrid Name="SongDataGrid" 
                                  RowHeaderWidth="0" 
                                  AutoGenerateColumns="false" 
                                  ColumnWidth="*" 
                                  IsReadOnly="True" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False" 
                                  CanUserResizeRows="False" 
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="None" 
                                  BorderBrush="{x:Null}">
                            <DataGrid.Resources>
                                <ResourceDictionary>
                                    <Style x:Key="{x:Type DataGridCell}" TargetType="{x:Type DataGridCell}">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Padding="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Background" Value="#282828" />
                                        <Setter Property="BorderBrush" Value="White" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2E2E2E" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2E2E2E" />
                                                <Setter Property="BorderBrush" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#322F3D"/>
                                        <Setter Property="Padding" Value="5,7,5,7"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                                    <Grid Background="{TemplateBinding Background}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <DockPanel>
                                                            <Path x:Name="SortArrow"
                                                                  DockPanel.Dock="Right"
                                                                  Margin="8,0,8,0"
                                                                  VerticalAlignment="Center"
                                                                  Width="8"
                                                                  Height="6"
                                                                  Stretch="Fill"
                                                                  Fill="White"
                                                                  Visibility="Collapsed"
                                                                  Data="M 0,6 L 4,0 L 8,6 Z"/>
                                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="SortDirection" Value="Ascending">
                                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="SortArrow" Property="Data" Value="M 0,6 L 4,0 L 8,6 Z"/>
                                                        </Trigger>
                                                        <Trigger Property="SortDirection" Value="Descending">
                                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,6 L 8,0 Z"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3E065F"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ResourceDictionary>
                            </DataGrid.Resources>
                            <DataGrid.Background>
                                <SolidColorBrush Color="{DynamicResource SideMenuButtonBackground}"/>
                            </DataGrid.Background>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Song Name" Binding="{Binding Name}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Artist" Binding="{Binding Artists}" Width="1.5*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Genres" Binding="{Binding Genres}" Width="1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BPM" Binding="{Binding BPM}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="0.8*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="0.6*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Downloads" Binding="{Binding Downloads}" Width="85">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="110" CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Click="Download_Click" 
                                                    HorizontalAlignment="Stretch" 
                                                    Padding="8,4,8,4" 
                                                    Content="{Binding ButtonText}" 
                                                    IsEnabled="{Binding DownloadEnabled}"
                                                    BorderThickness="0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Background" Value="#FF3F0071"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            CornerRadius="4" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <!-- Download button (enabled, purple) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Download"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#5865F2"/>
                                                            </MultiDataTrigger>
                                                            <!-- Update button (enabled, orange) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Update"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#E67E22"/>
                                                            </MultiDataTrigger>
                                                            <!-- Remove button (enabled, red) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Remove"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#E74C3C"/>
                                                            </MultiDataTrigger>
                                                            <!-- Local/Downloaded buttons (disabled, gray) -->
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#3A3A3A"/>
                                                                <Setter Property="Foreground" Value="#888888"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    
                    <!-- Pagination Controls for Songs Tab -->
                    <Border Grid.Row="1" Background="#322F3D" Padding="10" Margin="10,0,10,10" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Previous Button -->
                            <Button x:Name="SongsPreviousButton"
                                    Grid.Column="0"
                                    Content="◄ Previous"
                                    Click="SongsPreviousButton_Click"
                                    Padding="15,8,15,8"
                                    FontSize="12"
                                    Height="36"
                                    BorderThickness="0"
                                    IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#5865F2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="4" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Page Info -->
                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="SongsPageInfo" 
                                           Text="Page 1 of 1 (0 songs)" 
                                           Foreground="White" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Next Button -->
                            <Button x:Name="SongsNextButton"
                                    Grid.Column="2"
                                    Content="Next ►"
                                    Click="SongsNextButton_Click"
                                    Padding="15,8,15,8"
                                    FontSize="12"
                                    Height="36"
                                    BorderThickness="0"
                                    IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#5865F2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="4" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <Image Margin="3,3,3,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="40" Height="40" Source="/Icons/search.png"/>
                        <Label Content="Search" Foreground="White" Width="58" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search Panel -->
                    <Border Grid.Row="0" Background="#322F3D" Padding="20" Margin="10,10,10,5" CornerRadius="6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Search Songs" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Padding="0,0,0,0"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Name -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
                                    <TextBlock Text="Song Name" Foreground="White" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SearchNameTextBox" 
                                             Background="#282828" 
                                             Foreground="White" 
                                             BorderBrush="#444444" 
                                             Padding="8,6,8,6"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- Artist -->
                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,10,0">
                                    <TextBlock Text="Artist" Foreground="White" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SearchArtistTextBox" 
                                             Background="#282828" 
                                             Foreground="White" 
                                             BorderBrush="#444444" 
                                             Padding="8,6,8,6"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- Genre -->
                                <StackPanel Grid.Column="2" Grid.Row="0" Margin="10,0,0,0">
                                    <TextBlock Text="Genre" Foreground="White" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SearchGenreTextBox" 
                                             Background="#282828" 
                                             Foreground="White" 
                                             BorderBrush="#444444" 
                                             Padding="8,6,8,6"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- BPM -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,15,10,0">
                                    <TextBlock Text="BPM" Foreground="White" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SearchBPMTextBox" 
                                             Background="#282828" 
                                             Foreground="White" 
                                             BorderBrush="#444444" 
                                             Padding="8,6,8,6"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- Author -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,15,10,0">
                                    <TextBlock Text="Author" Foreground="White" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SearchAuthorTextBox" 
                                             Background="#282828" 
                                             Foreground="White" 
                                             BorderBrush="#444444" 
                                             Padding="8,6,8,6"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- Search Buttons -->
                                <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal" Margin="10,15,0,0" VerticalAlignment="Bottom">
                                    <Button x:Name="SearchButton"
                                            Content="Search"
                                            Click="SearchButton_Click"
                                            Padding="20,8,20,8"
                                            FontSize="12"
                                            Height="36"
                                            Margin="0,0,10,0"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#5865F2"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}" 
                                                                    CornerRadius="4" 
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button x:Name="ClearSearchButton"
                                            Content="Clear"
                                            Click="ClearSearchButton_Click"
                                            Padding="20,8,20,8"
                                            FontSize="12"
                                            Height="36"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#3A3A3A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}" 
                                                                    CornerRadius="4" 
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Search Results DataGrid -->
                    <Border Grid.Row="1" Background="Transparent" Margin="10,5,10,5" CornerRadius="6" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                        </Border.Effect>
                        <DataGrid Name="SearchResultsDataGrid" 
                                  RowHeaderWidth="0" 
                                  AutoGenerateColumns="false" 
                                  ColumnWidth="*" 
                                  IsReadOnly="True" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False" 
                                  CanUserResizeRows="False" 
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="None" 
                                  BorderBrush="{x:Null}">
                            <DataGrid.Resources>
                                <ResourceDictionary>
                                    <Style x:Key="{x:Type DataGridCell}" TargetType="{x:Type DataGridCell}">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Padding="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Background" Value="#282828" />
                                        <Setter Property="BorderBrush" Value="White" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2E2E2E" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2E2E2E" />
                                                <Setter Property="BorderBrush" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#322F3D"/>
                                        <Setter Property="Padding" Value="5,7,5,7"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                                    <Grid Background="{TemplateBinding Background}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <DockPanel>
                                                            <Path x:Name="SortArrow"
                                                                  DockPanel.Dock="Right"
                                                                  Margin="8,0,8,0"
                                                                  VerticalAlignment="Center"
                                                                  Width="8"
                                                                  Height="6"
                                                                  Stretch="Fill"
                                                                  Fill="White"
                                                                  Visibility="Collapsed"
                                                                  Data="M 0,6 L 4,0 L 8,6 Z"/>
                                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="SortDirection" Value="Ascending">
                                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="SortArrow" Property="Data" Value="M 0,6 L 4,0 L 8,6 Z"/>
                                                        </Trigger>
                                                        <Trigger Property="SortDirection" Value="Descending">
                                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,6 L 8,0 Z"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3E065F"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ResourceDictionary>
                            </DataGrid.Resources>
                            <DataGrid.Background>
                                <SolidColorBrush Color="{DynamicResource SideMenuButtonBackground}"/>
                            </DataGrid.Background>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Song Name" Binding="{Binding Name}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Artist" Binding="{Binding Artists}" Width="1.5*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Genres" Binding="{Binding Genres}" Width="1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BPM" Binding="{Binding BPM}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="0.8*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="0.6*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Downloads" Binding="{Binding Downloads}" Width="85">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="110" CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Click="Download_Click" 
                                                    HorizontalAlignment="Stretch" 
                                                    Padding="8,4,8,4" 
                                                    Content="{Binding ButtonText}" 
                                                    IsEnabled="{Binding DownloadEnabled}"
                                                    BorderThickness="0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Background" Value="#FF3F0071"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            CornerRadius="4" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <!-- Download button (enabled, purple) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Download"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#5865F2"/>
                                                            </MultiDataTrigger>
                                                            <!-- Update button (enabled, orange) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Update"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#E67E22"/>
                                                            </MultiDataTrigger>
                                                            <!-- Remove button (enabled, red) -->
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding ButtonText}" Value="Remove"/>
                                                                    <Condition Binding="{Binding DownloadEnabled}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#E74C3C"/>
                                                            </MultiDataTrigger>
                                                            <!-- Local/Downloaded buttons (disabled, gray) -->
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#3A3A3A"/>
                                                                <Setter Property="Foreground" Value="#888888"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    
                    <!-- Pagination Controls for Search Tab -->
                    <Border Grid.Row="2" Background="#322F3D" Padding="10" Margin="10,0,10,10" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Previous Button -->
                            <Button x:Name="SearchPreviousButton"
                                    Grid.Column="0"
                                    Content="◄ Previous"
                                    Click="SearchPreviousButton_Click"
                                    Padding="15,8,15,8"
                                    FontSize="12"
                                    Height="36"
                                    BorderThickness="0"
                                    IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#5865F2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="4" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Page Info -->
                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="SearchPageInfo" 
                                           Text="Page 1 of 1 (0 songs)" 
                                           Foreground="White" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Next Button -->
                            <Button x:Name="SearchNextButton"
                                    Grid.Column="2"
                                    Content="Next ►"
                                    Click="SearchNextButton_Click"
                                    Padding="15,8,15,8"
                                    FontSize="12"
                                    Height="36"
                                    BorderThickness="0"
                                    IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#5865F2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="4" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <Image Source="Icons/manage.png" Margin="3,3,3,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="40" Height="40"/>
                        <Label Content="Manage" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical" Margin="20,20,20,20" Background="#282828" VerticalAlignment="Top">
                        <!-- Upload Section -->
                        <TextBlock Text="Upload a New Song" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <StackPanel x:Name="UploadNotLoggedInPanel" Orientation="Vertical" Visibility="Visible" Margin="0,0,0,20">
                            <TextBlock Text="You must be logged in with Discord to upload songs." Foreground="#CCCCCC" Margin="0,0,0,10"/>
                            <TextBlock Text="Please log in from the Settings tab to upload." Foreground="#999999" FontSize="12"/>
                        </StackPanel>
                        
                        <StackPanel x:Name="UploadLoggedInPanel" Orientation="Vertical" Visibility="Collapsed" Margin="0,0,0,20">
                            <TextBlock Text="Select a ZIP file containing your song to upload" Foreground="#CCCCCC" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                                <Button x:Name="SelectSongButton"
                                        Content="Select ZIP File"
                                        Click="SelectSongButton_Click"
                                        Padding="12,8,12,8"
                                        FontSize="12"
                                        Height="36"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#5865F2"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border"
                                                                Background="{TemplateBinding Background}" 
                                                                CornerRadius="4" 
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock x:Name="SelectedFileText" Text="No file selected" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </StackPanel>
                            
                            <Button x:Name="UploadSongButton"
                                    Content="Upload Song"
                                    Click="UploadSongButton_Click"
                                    Padding="12,8,12,8"
                                    FontSize="12"
                                    Height="36"
                                    Width="140"
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#5865F2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}" 
                                                            CornerRadius="4" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#1A1A1A"/>
                                                            <Setter Property="Foreground" Value="#444444"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        
                        <Separator Margin="0,20,0,20" Background="#444444"/>
                        
                        <!-- Your Songs Section -->
                        <TextBlock Text="Your Uploaded Songs" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <StackPanel x:Name="NoSongsPanel" Orientation="Vertical" Visibility="Visible" Margin="0,0,0,10">
                            <TextBlock Text="You haven't uploaded any songs yet." Foreground="#999999" FontSize="12"/>
                        </StackPanel>
                        
                        <DataGrid x:Name="UserSongsDataGrid" 
                                  RowHeaderWidth="0" 
                                  AutoGenerateColumns="false" 
                                  ColumnWidth="*" 
                                  IsReadOnly="True" 
                                  CanUserAddRows="False" 
                                  CanUserDeleteRows="False" 
                                  CanUserResizeRows="False" 
                                  CanUserReorderColumns="False" 
                                  GridLinesVisibility="None" 
                                  BorderBrush="{x:Null}"
                                  Visibility="Collapsed"
                                  Margin="0,0,0,10">
                            <DataGrid.Resources>
                                <ResourceDictionary>
                                    <Style x:Key="{x:Type DataGridCell}" TargetType="{x:Type DataGridCell}">
                                        <Setter Property="Background" Value="#282828" />
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Padding="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF282828" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="Background" Value="#282828" />
                                        <Setter Property="BorderBrush" Value="White" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF282828" />
                                                <Setter Property="BorderBrush" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#322F3D"/>
                                        <Setter Property="Padding" Value="5,7,5,7"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#FF3F0071"/>
                                    </Style>
                                </ResourceDictionary>
                            </DataGrid.Resources>
                            <DataGrid.Background>
                                <SolidColorBrush Color="{DynamicResource SideMenuButtonBackground}"/>
                            </DataGrid.Background>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Song Name" Binding="{Binding Name}" />
                                <DataGridTextColumn Header="Artist" Binding="{Binding Artists}" />
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" />
                                <DataGridTemplateColumn Header="Actions" MinWidth="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="Update" 
                                                        Click="UpdateSongButton_Click" 
                                                        Padding="8,5,8,5" 
                                                        Margin="3" 
                                                        Width="65" 
                                                        FontSize="11"
                                                        BorderThickness="0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="Background" Value="#5865F2"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border"
                                                                                Background="{TemplateBinding Background}" 
                                                                                CornerRadius="4" 
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Delete" 
                                                        Click="DeleteSongButton_Click" 
                                                        Padding="8,5,8,5" 
                                                        Margin="3" 
                                                        Width="65" 
                                                        FontSize="11"
                                                        BorderThickness="0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="Background" Value="#E74C3C"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border"
                                                                                Background="{TemplateBinding Background}" 
                                                                                CornerRadius="4" 
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#EC5E4F"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <Image Source="Icons/settings.png" Margin="3,3,3,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="40" Height="40" />
                        <Label Content="Settings" HorizontalAlignment="Center" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <StackPanel Orientation="Vertical" Margin="20,20,20,20" Background="#282828">
                    <!-- Discord Authentication Section -->
                    <TextBlock Text="Discord Authentication" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <StackPanel x:Name="LoggedOutPanel" Orientation="Vertical" Visibility="Visible">
                        <TextBlock Text="You are not logged in" Foreground="#999999" Margin="0,0,0,10"/>
                        <Button x:Name="LoginButton" 
                                Content="Login with Discord" 
                                Click="LoginButton_Click"
                                Padding="12,8,12,8"
                                FontSize="12"
                                Height="36"
                                Width="150" 
                                HorizontalAlignment="Left"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#5865F2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}" 
                                                        CornerRadius="4" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    
                    <StackPanel x:Name="LoggedInPanel" Orientation="Vertical" Visibility="Collapsed">
                        <TextBlock x:Name="UserInfoText" Text="Logged in as: " Foreground="White" Margin="0,0,0,10"/>
                        <Button x:Name="LogoutButton" 
                                Content="Logout" 
                                Click="LogoutButton_Click"
                                Padding="12,8,12,8"
                                FontSize="12"
                                Height="36"
                                Width="100" 
                                HorizontalAlignment="Left"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}" 
                                                        CornerRadius="4" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    
                    <Separator Margin="0,20,0,20" Background="#444444"/>
                    
                    <!-- Electronauts Path Section -->
                    <TextBlock Text="Electronauts Path" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Label x:Name="testLabel" Content="Loading..." Foreground="White" Margin="0,0,0,20"/>
                    
                    <Separator Margin="0,0,0,20" Background="#444444"/>
                    
                    <!-- Data Management Section -->
                    <TextBlock Text="Data Management" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Delete all saved settings including paths, authentication tokens, and preferences." 
                               Foreground="#CCCCCC" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>
                    <Button x:Name="DeleteAllDataButton" 
                            Content="Delete All Data" 
                            Click="DeleteAllDataButton_Click"
                            Padding="12,8,12,8"
                            FontSize="12"
                            Height="36"
                            Width="140" 
                            HorizontalAlignment="Left"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E74C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}" 
                                                    CornerRadius="4" 
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#EC5E4F"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <Image Source="Icons/about.png" Margin="3,3,3,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="40"/>
                        <Label Content="About" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"></Label>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer x:Name="AboutScrollViewer" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                    <StackPanel Orientation="Vertical" Margin="20,20,20,20" Background="#282828" VerticalAlignment="Top">
                        <!-- Logo Section -->
                        <Border HorizontalAlignment="Center" Margin="0,0,0,20" Background="#322F3D" CornerRadius="8" Padding="20">
                            <Image x:Name="AppLogo" 
                                   Width="120" 
                                   Height="120" 
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center" Source="/Icons/logo.png"/>
                        </Border>

                        <!-- App Information Section -->
                        <TextBlock Text="ElectroMods" 
                                   Foreground="White" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="Song Manager for Electronauts" 
                                   Foreground="#CCCCCC" 
                                   FontSize="14" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,20"/>

                        <Separator Margin="0,0,0,20" Background="#444444"/>

                        <!-- Version Information -->
                        <TextBlock Text="Version Information" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Version: " Foreground="#CCCCCC" Width="100"/>
                            <TextBlock Text="1.0.0" Foreground="White"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Built with: " Foreground="#CCCCCC" Width="100"/>
                            <TextBlock Text=".NET 10" Foreground="White"/>
                        </StackPanel>

                        <Separator Margin="0,20,0,20" Background="#444444"/>

                        <!-- Description -->
                        <TextBlock Text="About This Application" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Foreground="#CCCCCC" 
                                   LineHeight="20" 
                                   Margin="0,0,0,20">
                            ElectroMods is a community-driven song manager for Electronauts VR. 
                            Browse, download, and manage custom songs created by the community. 
                            Upload your own creations and share them with other players around the world.
                        </TextBlock>

                        <Separator Margin="0,0,0,20" Background="#444444"/>

                        <!-- Credits Section -->
                        <TextBlock Text="Credits" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Developer: " Foreground="#CCCCCC" Width="100"/>
                            <TextBlock Text="zer0ney" Foreground="White"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Game by: " Foreground="#CCCCCC" Width="100"/>
                            <TextBlock Text="Survios" Foreground="White"/>
                        </StackPanel>

                        <Separator Margin="0,20,0,20" Background="#444444"/>

                        <!-- Support Section -->
                        <TextBlock Text="Support &amp; Community" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Join our Discord community for support, updates, and to connect with other creators!" 
                                   Foreground="#CCCCCC" 
                                   TextWrapping="Wrap" 
                                   Margin="0,0,0,15"/>
                        
                        <Button x:Name="DiscordSupportButton"
                                Content="Join Discord Server"
                                Click="DiscordSupportButton_Click"
                                Padding="15,10,15,10"
                                FontSize="14"
                                Height="42"
                                Width="200"
                                BorderThickness="0"
                                HorizontalAlignment="Left">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#5865F2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}" 
                                                        CornerRadius="4" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Image Source="Icons/discord-square-icon.png"
                                                               Width="24" 
                                                               Height="24" 
                                                               Margin="0,0,10,0" 
                                                               VerticalAlignment="Center"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{TemplateBinding Content}" 
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{TemplateBinding Foreground}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#6B75F5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#4A54D1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,20,0,20" Background="#444444"/>

                        <!-- Legal Section -->
                        <TextBlock Text="Legal" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Foreground="#999999" 
                                   FontSize="11" 
                                   LineHeight="18" 
                                   Margin="0,0,0,10">
                            ElectroMods is an unofficial, community-created tool and is not affiliated with, 
                            endorsed by, or connected to Survios or Electronauts. All trademarks and copyrights 
                            belong to their respective owners.
                        </TextBlock>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Foreground="#999999" 
                                   FontSize="11" 
                                   LineHeight="18">
                            This software is provided "as is" without warranty of any kind. 
                            Use at your own risk.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
